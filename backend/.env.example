# MongoDB connection string (Atlas-style example)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/devdiscuss?retryWrites=true&w=majority&appName=Cluster0

# Server settings
PORT=4000
JWT_SECRET=replace_with_a_secure_secret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI provider settings
# Preferred for this project: OpenRouter
OPENROUTER_API_KEY=replace_with_your_openrouter_key
OPENROUTER_EXECUTION_MODEL=openai/gpt-4o-mini
OPENROUTER_EXECUTION_TIMEOUT_MS=30000

# Optional fallback for OpenAI-compatible providers
OPENAI_API_KEY=replace_with_your_openai_or_openai_compatible_key
